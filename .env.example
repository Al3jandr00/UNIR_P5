# ── Base de datos ──────────────────────────────────────────────────────────────
# Opción A: URL completa (tiene prioridad)
DB_URL=

# Opción B: parámetros individuales (usados si DB_URL está vacía)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tasks
DB_USER=postgres
DB_PASSWORD=postgres

# ── Proveedor OpenAI directo ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# ── Proveedor Azure OpenAI (tiene prioridad sobre OpenAI si está configurado) ──
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
AZURE_OPENAI_MODEL=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Parámetros del modelo ──────────────────────────────────────────────────────
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=350
OPENAI_TOP_P=1.0

# ── Activar fallback local (útil en tests y cuando no hay credenciales IA) ─────
AI_ALLOW_LOCAL_FALLBACK=false
